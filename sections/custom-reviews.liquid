<div class="pw-reviews premium-wellness-section">
  <div class="pw-reviews__container">
    {%- if section.settings.title != blank or section.settings.description != blank -%}
      <div class="pw-reviews__header">
        {%- if section.settings.title != blank -%}
          <h2 class="pw-reviews__title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="pw-reviews__desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="pw-reviews__grid">
      {%- liquid
        assign has_custom_blocks = false
        if section.blocks.size > 0
          assign has_custom_blocks = true
        endif
      -%}

      {%- if has_custom_blocks -%}
        {%- for block in section.blocks -%}
          <div class="pw-review-card" {{ block.shopify_attributes }}>
            <div class="pw-review-card__stars">
              {%- assign rating = block.settings.stars | plus: 0 -%}
              {%- for i in (1..rating) -%}
                <svg class="pw-review-card__star-icon" viewBox="0 0 24 24" fill="currentColor" style="color: #ffc107;">
                  <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                </svg>
              {%- endfor -%}
            </div>
            
            {%- if block.settings.content != blank -%}
              <blockquote class="pw-review-card__content">
                "{{ block.settings.content }}"
              </blockquote>
            {%- endif -%}
            
            <div class="pw-review-card__author">
              <div class="pw-review-card__author-info">
                {%- if block.settings.author != blank -%}
                  <span class="pw-review-card__author-name">{{ block.settings.author }}</span>
                {%- endif -%}
                {%- if block.settings.verified -%}
                  <span class="pw-review-card__author-status" style="color: #2E7D32; font-weight: 600;">
                    <svg class="pw-review-card__checkmark" viewBox="0 0 24 24" style="width: 12px; height: 12px; fill: currentColor;">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                    </svg>
                    Verified Buyer
                  </span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {% comment %} Fallback: Render premium product-specific reviews based on product handle {% endcomment %}
        {%- liquid
          # Get product handle
          assign current_product = product | default: closest.product
          assign p_handle = current_product.handle
          
          # Initialize default reviews (Nail fungal oil)
          assign r1_author = "Dr. Rajesh Patel"
          assign r1_verified = true
          assign r1_stars = 5
          assign r1_content = "I had severe paronychia nail infection on my big toe for 6 months. Within 5 days of using this relief oil, the throbbing pain stopped and the redness is completely gone! Highly recommended!"
          
          assign r2_author = "Neha Sharma"
          assign r2_verified = true
          assign r2_stars = 5
          assign r2_content = "This nail oil is a lifesaver. It absorbed quickly under the nail bed. My yellow, damaged nail is growing out healthy and clean now. Excellent quality product."
          
          assign r3_author = "Karan Singh"
          assign r3_verified = true
          assign r3_stars = 5
          assign r3_content = "Works extremely fast! The swelling went down in just 2 days. The oil is soothing and does not smell strong."
          
          if p_handle contains "massage" or p_handle contains "soothing" or p_handle contains "gel" or p_handle contains "mitsui" or p_handle contains "joint" or p_handle contains "muscle"
            assign r1_author = "Sanjay Verma"
            assign r1_verified = true
            assign r1_stars = 5
            assign r1_content = "My chronic knee pain and joint stiffness are completely gone! This Japanese soothing massage gel works better than any prescription balm I have tried. Instant relief!"
            
            assign r2_author = "Sunita Rao"
            assign r2_verified = true
            assign r2_stars = 5
            assign r2_content = "Perfect for post-workout muscle soreness. It has a cooling effect that penetrates deep into the muscle. I apply it every night."
            
            assign r3_author = "Amit Mehta"
            assign r3_verified = true
            assign r3_stars = 5
            assign r3_content = "Excellent gel. It is non-sticky and gets absorbed within seconds. My father uses it daily for his shoulder arthritis and feels much better."
          endif
        -%}

        <!-- Card 1 -->
        <div class="pw-review-card">
          <div class="pw-review-card__stars">
            {%- for i in (1..r1_stars) -%}
              <svg class="pw-review-card__star-icon" viewBox="0 0 24 24" fill="currentColor" style="color: #ffc107; width: 16px; height: 16px;">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            {%- endfor -%}
          </div>
          <blockquote class="pw-review-card__content">
            "{{ r1_content }}"
          </blockquote>
          <div class="pw-review-card__author">
            <div class="pw-review-card__author-info">
              <span class="pw-review-card__author-name">{{ r1_author }}</span>
              <span class="pw-review-card__author-status" style="color: #2E7D32; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; margin-top: 4px;">
                <svg class="pw-review-card__checkmark" viewBox="0 0 24 24" style="width: 12px; height: 12px; fill: currentColor;">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                Verified Buyer
              </span>
            </div>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="pw-review-card">
          <div class="pw-review-card__stars">
            {%- for i in (1..r2_stars) -%}
              <svg class="pw-review-card__star-icon" viewBox="0 0 24 24" fill="currentColor" style="color: #ffc107; width: 16px; height: 16px;">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            {%- endfor -%}
          </div>
          <blockquote class="pw-review-card__content">
            "{{ r2_content }}"
          </blockquote>
          <div class="pw-review-card__author">
            <div class="pw-review-card__author-info">
              <span class="pw-review-card__author-name">{{ r2_author }}</span>
              <span class="pw-review-card__author-status" style="color: #2E7D32; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; margin-top: 4px;">
                <svg class="pw-review-card__checkmark" viewBox="0 0 24 24" style="width: 12px; height: 12px; fill: currentColor;">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                Verified Buyer
              </span>
            </div>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="pw-review-card">
          <div class="pw-review-card__stars">
            {%- for i in (1..r3_stars) -%}
              <svg class="pw-review-card__star-icon" viewBox="0 0 24 24" fill="currentColor" style="color: #ffc107; width: 16px; height: 16px;">
                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
              </svg>
            {%- endfor -%}
          </div>
          <blockquote class="pw-review-card__content">
            "{{ r3_content }}"
          </blockquote>
          <div class="pw-review-card__author">
            <div class="pw-review-card__author-info">
              <span class="pw-review-card__author-name">{{ r3_author }}</span>
              <span class="pw-review-card__author-status" style="color: #2E7D32; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; margin-top: 4px;">
                <svg class="pw-review-card__checkmark" viewBox="0 0 24 24" style="width: 12px; height: 12px; fill: currentColor;">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
                Verified Buyer
              </span>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Reviews",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Loved by 10,000+ Happy Customers"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "See how our premium pain-relief solutions are helping real people reclaim their active lives."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "select",
          "id": "stars",
          "label": "Stars Rating",
          "options": [
            { "value": "5", "label": "5 Stars" },
            { "value": "4", "label": "4 Stars" }
          ],
          "default": "5"
        },
        {
          "type": "textarea",
          "id": "content",
          "label": "Review Content",
          "default": "After years of joint pain, I finally found something that actually works. Within 3 days of applying the balm, my knee stiffness was completely gone!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Reviewer Name",
          "default": "Ramesh K."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Buyer Checkmark",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author": "Aarav S.",
            "content": "This pain-relief ointment works like magic. It is non-greasy, absorbs immediately, and blocks the throbbing back pain in minutes."
          }
        },
        {
          "type": "review",
          "settings": {
            "author": "Dr. Priya M.",
            "content": "I recommend these wellness formulas to my patients. Excellent clinical profile and highly bioavailable ingredients."
          }
        },
        {
          "type": "review",
          "settings": {
            "author": "Vikram J.",
            "content": "Fantastic product! I use it after workouts to prevent muscle cramps and stiffness. Very fast shipping too."
          }
        }
      ]
    }
  ]
}
{% endschema %}
