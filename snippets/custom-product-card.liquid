{% comment %}
  Renders a custom product card.
  Usage:
  {% render 'custom-product-card', product: product %}
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
-%}

<div class="pw-product-card" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="pw-product-card__image-link" aria-label="View {{ product.title | escape }}">
    {%- if product.featured_media != blank -%}
      <img
        src="{{ product.featured_media | image_url: width: 600 }}"
        sizes="(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw"
        srcset="{{ product.featured_media | image_url: width: 300 }} 300w,
                {{ product.featured_media | image_url: width: 450 }} 450w,
                {{ product.featured_media | image_url: width: 600 }} 600w,
                {{ product.featured_media | image_url: width: 800 }} 800w"
        alt="{{ product.featured_media.alt | escape | default: product.title }}"
        class="pw-product-card__image"
        width="{{ product.featured_media.width }}"
        height="{{ product.featured_media.height }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'pw-product-card__image placeholder-svg' }}
    {%- endif -%}

    {%- if on_sale -%}
      {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
      <span class="pw-product-card__badge">Save {{ discount }}%</span>
    {%- endif -%}
  </a>

  <div class="pw-product-card__info">
    <a href="{{ product.url }}" class="pw-product-card__title">
      {{ product.title }}
    </a>
    
    <div class="pw-product-card__price-wrapper" style="margin-bottom: 8px;">
      <span class="pw-product-card__price" style="color: #2e7d32; font-weight: 700;">{{ current_variant.price | money }}</span>
      {%- if on_sale -%}
        <span class="pw-product-card__compare-price">{{ current_variant.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    {% comment %} Dynamic reviews and sold stats for homepage featured cards {% endcomment %}
    {% liquid
      assign product_seed = product.id | default: 123456789
      assign days_since_epoch = "now" | date: "%s" | divided_by: 86400 | plus: 0
      assign days_diff = days_since_epoch | minus: 20597
      if days_diff < 0
        assign days_diff = 0
      endif
      
      # Total reviews count (starts at 126 for Product A, 187 for Product B, increases by 2 or 3 per day)
      assign p_handle = product.handle
      if p_handle contains "massage" or p_handle contains "soothing" or p_handle contains "gel" or p_handle contains "mitsui" or p_handle contains "joint" or p_handle contains "muscle"
        assign dynamic_increment = days_diff | times: 3
        assign card_reviews = 187 | plus: dynamic_increment
      else
        assign dynamic_increment = days_diff | times: 2
        assign card_reviews = 126 | plus: dynamic_increment
      endif
      
      # Sold count and hours (fluctuates daily based on day of year, which is fine and looks realistic!)
      assign day_seed = "now" | date: "%j" | plus: 0
      assign combined_seed = product_seed | plus: day_seed
      assign sold_count = combined_seed | modulo: 11 | plus: 15
      assign sold_hours = combined_seed | modulo: 3 | plus: 1
    %}
    
    <!-- Stars & Review count -->
    <div class="card-reviews-indicator" style="display: flex; align-items: center; gap: 4px; margin-top: 2px; margin-bottom: 4px; font-family: var(--font-body--family);">
      <div style="display: flex; align-items: center; color: #ffc107; font-size: 0.95rem; gap: 2px;">
        {% for star in (1..5) %}
          <svg style="width: 14px; height: 14px; fill: #ffc107;" viewBox="0 0 32 32">
            <path d="M31.547 12a.848.848 0 00-.677-.577l-9.427-1.376-4.224-8.532a.847.847 0 00-1.516 0l-4.218 8.534-9.427 1.355a.847.847 0 00-.467 1.467l6.823 6.664-1.612 9.375a.847.847 0 001.23.893l8.428-4.434 8.432 4.432a.847.847 0 001.229-.894l-1.615-9.373 6.822-6.665a.845.845 0 00.214-.869z" />
          </svg>
        {% endfor %}
      </div>
      <span style="font-size: 0.85rem; color: #555555; font-weight: 600; margin-left: 2px;">{{ card_reviews }} Reviews</span>
    </div>
    
    <!-- Sold count 🔥 -->
    <div class="card-sold-indicator" style="color: #ff3333; font-weight: 700; font-size: 0.85rem; margin-top: 2px; margin-bottom: 12px; display: flex; align-items: center; gap: 4px; line-height: 1;">
      <span>🔥</span>
      <span>{{ sold_count }} sold in last {{ sold_hours }} {% if sold_hours == 1 %}hour{% else %}hours{% endif %}</span>
    </div>

    {%- if current_variant -%}
      <product-form-component data-product-id="{{ product.id }}" id="product-form-{{ section.id }}-{{ product.id }}" class="pw-product-card__form">
        {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" ref="variantId">
          <input type="hidden" name="quantity" value="1">
          <div ref="liveRegion" class="visually-hidden" aria-live="polite"></div>
          <div ref="addToCartTextError" class="pw-product-card__error hidden" style="color: red; font-size: 0.8rem; margin-bottom: 8px;"></div>
          
          <add-to-cart-component ref="addToCartButtonContainer" class="add-to-cart-component">
            <button
              type="submit"
              ref="addToCartButton"
              class="pw-product-card__btn"
              {% unless current_variant.available %}disabled{% endunless %}
              aria-label="Add {{ product.title | escape }} to cart"
            >
              <span>
                {%- if current_variant.available -%}
                  Add to Cart
                {%- else -%}
                  Sold Out
                {%- endif -%}
              </span>
            </button>
          </add-to-cart-component>
        {%- endform -%}
      </product-form-component>
    {%- endif -%}
  </div>
</div>
